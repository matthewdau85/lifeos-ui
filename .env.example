# LifeOS Frontend — Environment Variables
# Copy to .env.local for local development.
# Set these in Vercel dashboard → Project → Settings → Environment Variables for production.

# URL of your LifeOS backend server (Railway deployment URL or localhost for dev)
# Example: https://lifeos-backend-production.up.railway.app
# Leave empty to fall back to http://localhost:3000 for local development
VITE_LIFEOS_API_URL=
